# Copy this file to .env.local and fill only the providers you want to use.
#
# Optional provider selector. In auto mode the agent prefers OpenRouter, then
# Groq, then Anthropic when the matching key is configured and syntactically safe.
FIND_EVIL_AGENT_PROVIDER=auto
#
# Implemented runtimes:
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
#
# Local Windows launcher override:
MCP_SERVER_COMMAND=py
